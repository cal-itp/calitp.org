---
layout: default
---
{% if asset %}
  {% assign url = asset %}
  {% unless asset contains 'https://' %}
    {% assign url = '/assets/' | append: url %}
  {% endunless %}
  {% include 'script_redirect', location: url %}
{% endif %}

{% capture date %}
  {% include "date" date: date format: "%B %e, %Y" %}
{% endcapture %}
<div class="row justify-content-center">
  <div class="col-lg-8 col-md-8">
    <article class="press-release pb-5 mb-5">
      <a class="d-block text-decoration-none mb-2 pt-3 mt-5" href="/resources">Resource</a>
      <h1 class="h2">{{ title }}</h1>
      <hr>
      <p>{{ date }}</p>
      {{ content }}
    </article>
  </div>
</div>
